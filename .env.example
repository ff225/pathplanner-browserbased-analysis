DJANGO_DEBUG=0
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=pathplanner.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://pathplanner.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_STATIC_ROOT=/app/staticfiles
DJANGO_MEDIA_ROOT=/app/uploads
DJANGO_SQLITE_PATH=/app/data/db.sqlite3
MAPBOX_ACCESS_TOKEN=
OPENAQ_API_KEY=

# Optional demo routing engine. When set, backend clinical routing first asks a
# local/self-hosted GraphHopper instance for real OSM route candidates, scores
# them with the app's clinical/environmental weights, and falls back to Overpass
# street-graph A* if GraphHopper is unavailable.
GRAPHHOPPER_URL=
GRAPHHOPPER_API_KEY=
GRAPHHOPPER_TIMEOUT_SECONDS=8
GRAPHHOPPER_FORCE=false
GRAPHHOPPER_PROFILE_WALKING=foot
GRAPHHOPPER_PROFILE_CYCLING=bike
GRAPHHOPPER_PROFILE_CAR=car

# Docker Compose GraphHopper service defaults. These paths are inside the
# graphhopper container, where ./pbf is mounted at /work/pbf and
# ./runtime/graphhopper is mounted at /work/runtime/graphhopper.
GRAPHHOPPER_JAVA_HEAP=10g
GRAPHHOPPER_BIND_ADDRESS=127.0.0.1
GRAPHHOPPER_ITALY_PORT=8989
GRAPHHOPPER_ITALY_ADMIN_PORT=8990
GRAPHHOPPER_LONDON_PORT=8991
GRAPHHOPPER_LONDON_ADMIN_PORT=8992
GRAPHHOPPER_NEW_YORK_PORT=8993
GRAPHHOPPER_NEW_YORK_ADMIN_PORT=8994

# Region registry format:
# id|min_lat,min_lon,max_lat,max_lon|graphhopper_url|local_sqlite_db;...
# The backend picks the matching region from start/end coordinates and uses the
# matching GraphHopper service plus matching local SQLite POI/walkability DB.
PATHPLANNER_ROUTING_REGIONS=italy|32.90,-5.52,47.26,21.72|http://graphhopper-italy:8989|/app/runtime/local_osm_pois/italy.sqlite3;london|51.20,-0.65,51.75,0.45|http://graphhopper-london:8989|/app/runtime/local_osm_pois/london.sqlite3;new-york|40.40,-74.35,41.05,-73.55|http://graphhopper-new-york:8989|/app/runtime/local_osm_pois/new-york.sqlite3

# Local OSM-derived POI/walkability database. On a server, mount the PBF and
# runtime directory, then run scripts/ensure_local_osm_poi_db.py or enable the
# optional Docker entrypoint bootstrap.
LOCAL_OSM_POI_DB=
LOCAL_OSM_PBF_PATH=
LOCAL_OSM_POI_BUILD_MODE=full
LOCAL_OSM_POI_MIN_ROWS=1
LOCAL_OSM_WALKABILITY_MIN_ROWS=1
LOCAL_OSM_POI_FORCE_REBUILD=false
PATHPLANNER_ENSURE_LOCAL_OSM_DB=false
